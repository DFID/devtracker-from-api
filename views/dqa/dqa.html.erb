<div id="full_hero" class="full_width secondary">
  <div class="govuk-width-container">
    <!-- HEADER - START -->
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        <!-- <span class="govuk-caption-l">FCDO Development Tracker</span> -->
        <h1 class="govuk-heading-l govuk-!-margin-bottom-4">
          IATI Data Completeness Dashboard
        </h1>
      </div>
    </div>
    <!-- HEADER - END -->

    <!-- FILTER - START -->
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        <div class="filter_header">
          <div class="govuk-form-group">
            <label class="govuk-label" for="sort_Organisation"
              >Organisation</label
            >
            <select
              class="govuk-select"
              id="sort_Organisation"
              name="sort_Organisation"
            >
               <% orgList.each do |org| %>
                    <option value="<%= org['identifiers']%>"><%= org['name']%></option>
               <% end %>
            </select>
            <input id="selected_org" type="hidden" value="GB-GOV-1" />
          </div>
          <div class="govuk-form-group">
            <label class="govuk-label" for="sort_Country">Country/Region</label>
            <select class="govuk-select" id="sort_Country" name="sort_Country">
              <% country_region_list.each do |cr| %>
                    <option value="<%= cr[:code]%>"><%= cr[:title]%></option>
               <% end %>
            </select>
            <input id="selected_country_region" type="hidden" />
          </div>

          <div class="govuk-form-group">
            <label class="govuk-label" for="sort_Sector">Sector</label>
            <select class="govuk-select" id="sort_Sector" name="sort_Sector">
              <option value="">All</option>
              <% sector_list.each do |key, val| %>
                    <option value="<%= key%>"><%= val%></option>
               <% end %>
            </select>
            <input id="selected_sector" type="hidden" />
          </div>
        </div>
      </div>
    </div>
    <!-- FILTER - END -->
  </div>
</div>
