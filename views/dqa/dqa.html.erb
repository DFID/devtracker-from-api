    <script
      type="text/javascript"
      src="dqa/assets/javascripts/autocomplete.js"
    ></script>
    <script src="/assets/js/jquery-3.6.0.min.js"></script>
    <script src="/javascripts/d3.v3.js" type="text/javascript"></script>
    <script src="/javascripts/c3.min-12912fb6.js" type="text/javascript"></script>
    <script>
          $(document).ready(function(){
            // Initiate the necessary chart variables
            var overallDonut = null;
            var projectDonut = null;
            var programmeDonut = null;
            var docPubDonut = null;
            function cleanChart(chart){
              if(chart){
                chart.destroy();
              }
            }
            function setBarGraphData(titleTag,heightData,percentage){
              $(`#${titleTag}`).text(`${percentage}%`);
              $(`#${heightData}`).css('height', `${percentage}%`)
            }
            function getDonutThresholdColor(passFailType,PassPercentage){
              if(passFailType == 'pass') {
                if(PassPercentage >= (100-PassPercentage)){
                  if(PassPercentage > 95){
                    return '#cfe4dc';
                  }
                  else if(PassPercentage >= 90){
                    return '#ffee80';
                  }
                  else {
                    return '#f4d7d7';
                  }
                }
                else {
                  return '#FFFFFF';
                }
              }
              else {
                if(PassPercentage >= (100-PassPercentage)){
                  return '#FFFFFF';
                }
                else {
                  if((100-PassPercentage) > 95){
                    return '#f4d7d7';
                  }
                  else {
                    return '#f4d7d7';
                  }
                }
              }
            }
            function generateDonut(divID, overallPercentage){
              return c3.generate({
                bindto: '#' + divID,
                size: {
                  height: 240,
                  width: 240
                },
                data: {
                    columns: [
                      ['Passed', overallPercentage],
                      ['Failed', (100-overallPercentage)]
                    ],
                    type : 'donut',
                    width: 35,
                    label: {
                      show: false
                    },
                    axis: {
                      // The image shows the data starting at 12 o'clock
                      // We set the total range and let the internal logic create the gap
                      y: {
                          max: 100,
                          min: 0,
                          show: false
                      }
                    },
                    colors: {
                      // 3. Set the custom mint green color
                      'Passed': getDonutThresholdColor('pass',overallPercentage),//'#cfe4dc',
                      'Failed': getDonutThresholdColor('',overallPercentage)
                    },
                    labels: false
                },
                donut: {
                  title: overallPercentage+"% Pass",
                  label: {
                    show: false
                  }
                },
                onrendered: function() {
                  // Find the title element
                  var titleNode = d3.select(`#${divID} .c3-chart-arcs-title`);
                  titleNode.html(""); // Clear it
                  
                  // Add the top line (The Percentage)
                  titleNode.append('tspan')
                      .text(`${overallPercentage}%`)
                      .attr('x', 0)
                      .attr('dy', '-0.2em')
                      .style('font-size', '40px')
                      .style('font-weight', 'bold')
                      .style('fill', '#000');

                  // Add the bottom line (The Label)
                  titleNode.append('tspan')
                      .text('Pass')
                      .attr('x', 0)
                      .attr('dy', '1.5em')
                      .style('font-size', '16px')
                      .style('font-weight', 'normal')
                      .style('fill', '#999');
                },
                legend: {
                  hide: true
                }
              });
            }
            function generateCharts(selectedOrg, c_r_string, sector_string){
              //if(1==1){
                $.ajax({
                  url: '/dqa-request',
                  type: 'POST',
                  data: { org_id: selectedOrg, c_r_string: c_r_string, sector_string: sector_string },
                  dataType: 'json',
                  beforeSend: function(){
                    $('#main_content').hide();
                    $('#dashboard_loading').show();
                    $('#dashboard_V1_content').hide();
                    $('#dashboard_loading_content').show();
                  },
                  success: function(response) {
                    $('#dqa_active_prog_count').text(response.output.ActiveProgrammeCount)
                    $('#dqa_active_proj_count').text(response.output.ActiveProjectCount);
                    $('#dqa_total_budget').text('£' + response.output.TotalBudget);
                    cleanChart(overallDonut);
                    overallDonut = generateDonut('counter_overall_percentage', response.output.OverallPassRate);
                    cleanChart(projectDonut);
                    projectDonut = generateDonut('counter_proj_data_percentage', response.output.ProjectPassRate)
                    cleanChart(programmeDonut);
                    programmeDonut = generateDonut('counter_prog_data_percentage', response.output.ProgrammePassRate);
                    cleanChart(docPubDonut);
                    docPubDonut = generateDonut('counter_doc_pub_percentage', response.output.DocumentPassRate);
                    setBarGraphData('bar_title_val', 'bar_title_percentage', response.output.ProgrammeRAGBreakdown.Title);
                    setBarGraphData('bar_desc_val', 'bar_desc_percentage', response.output.ProgrammeRAGBreakdown.Description);
                    setBarGraphData('bar_startDate_val', 'bar_startDate_percentage', response.output.ProgrammeRAGBreakdown.StartDate);
                    setBarGraphData('bar_endDate_val', 'bar_endDate_percentage', response.output.ProgrammeRAGBreakdown.EndDate);
                    setBarGraphData('bar_sector_val', 'bar_sector_percentage', response.output.ProgrammeRAGBreakdown.Sector);
                    setBarGraphData('bar_loc_val', 'bar_loc_percentage', response.output.ProgrammeRAGBreakdown.Location);
                    setBarGraphData('bar_partiOrg_val', 'bar_partiOrg_percentage', response.output.ProgrammeRAGBreakdown.ParticipatingOrg);
                    //
                    setBarGraphData('proj_bar_title_val', 'proj_bar_title_percentage', response.output.ProjectRAGBreakdown.Title);
                    setBarGraphData('proj_bar_desc_val', 'proj_bar_desc_percentage', response.output.ProjectRAGBreakdown.Description);
                    setBarGraphData('proj_bar_startDate_val', 'proj_bar_startDate_percentage', response.output.ProjectRAGBreakdown.StartDate);
                    setBarGraphData('proj_bar_endDate_val', 'proj_bar_endDate_percentage', response.output.ProjectRAGBreakdown.EndDate);
                    setBarGraphData('proj_bar_sector_val', 'proj_bar_sector_percentage', response.output.ProjectRAGBreakdown.Sector);
                    setBarGraphData('proj_bar_loc_val', 'proj_bar_loc_percentage', response.output.ProjectRAGBreakdown.Location);
                    setBarGraphData('proj_bar_partiOrg_val', 'proj_bar_partiOrg_percentage', response.output.ProjectRAGBreakdown.ParticipatingOrg);
                    //
                    setBarGraphData('bar_bc_val', 'bar_bc_percentage', response.output.DocumentRAGBreakdown.BusinessCase);
                    setBarGraphData('bar_lf_val', 'bar_lf_percentage', response.output.DocumentRAGBreakdown.LogFrame);
                    setBarGraphData('bar_ar_val', 'bar_ar_percentage', response.output.DocumentRAGBreakdown.AnnualReview);
                    setBarGraphData('bar_pcr_val', 'bar_pcr_percentage', response.output.DocumentRAGBreakdown.PCR);
                    // Overall RAG breakdowns
                    setBarGraphData('overall_bar_title_val', 'overall_bar_title_percentage', response.output.OverallRAGBreakdown.Title);
                    setBarGraphData('overall_bar_desc_val', 'overall_bar_desc_percentage', response.output.OverallRAGBreakdown.Description);
                    setBarGraphData('overall_bar_startDate_val', 'overall_bar_startDate_percentage', response.output.OverallRAGBreakdown.StartDate);
                    setBarGraphData('overall_bar_endDate_val', 'overall_bar_endDate_percentage', response.output.OverallRAGBreakdown.EndDate);
                    setBarGraphData('overall_bar_sector_val', 'overall_bar_sector_percentage', response.output.OverallRAGBreakdown.Sector);
                    setBarGraphData('overall_bar_loc_val', 'overall_bar_loc_percentage', response.output.OverallRAGBreakdown.Location);
                    setBarGraphData('overall_bar_partiOrg_val', 'overall_bar_partiOrg_percentage', response.output.OverallRAGBreakdown.ParticipatingOrg);
                    setBarGraphData('overall_bar_bc_val', 'overall_bar_bc_percentage', response.output.OverallRAGBreakdown.BusinessCase);
                    setBarGraphData('overall_bar_lf_val', 'overall_bar_lf_percentage', response.output.OverallRAGBreakdown.LogFrame);
                    setBarGraphData('overall_bar_ar_val', 'overall_bar_ar_percentage', response.output.OverallRAGBreakdown.AnnualReview);
                    setBarGraphData('overall_bar_pcr_val', 'overall_bar_pcr_percentage', response.output.OverallRAGBreakdown.PCR);
                    setBarGraphData('overall_bar_partners_val', 'overall_bar_partners_percentage', response.output.OverallRAGBreakdown.PartnerLinks);
                  },
                  complete: function(){
                    $('#dashboard_loading').hide();
                    $('#dashboard_loading_content').hide();
                    $('#main_content').show();
                    $('#dashboard_V1_content').show();
                  }
                });
              //}
            }
            generateCharts('GB-GOV-1', '', '');
            $('#sort_Organisation').on('change', function(){
              var data = $(this).val();
              $('#selected_org').val(data);
              generateCharts($('#selected_org').val(), $('#selected_country_region').val(), $('#selected_sector').val())
            });
            $('#sort_Country').on('change', function(){
              var data = $(this).val();
              $('#selected_country_region').val(data);
              generateCharts($('#selected_org').val(), $('#selected_country_region').val(), $('#selected_sector').val())
            });
            $('#sort_Sector').on('change', function(){
              var data = $(this).val();
              console.log('ascasc');
              $('#selected_sector').val(data);
              generateCharts($('#selected_org').val(), $('#selected_country_region').val(), $('#selected_sector').val())
            });
          });
    </script>
  </main>
</div>