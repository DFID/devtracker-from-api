          <!-- CONTENT - START -->
          <div class="content">
            <!-- SECTION 1 - START -->
            <h2 class="govuk-heading-m">Activity Scope</h2>
            <h3 class="govuk-heading-s">Included Activities</h3>
            <p>
              The assessment covers
              <strong>all Programmes (H1 activities)</strong> at implementation
              stage and <strong>all Projects (H2 activities)</strong> where
              appropriate — that is, where the relevant data element exists.
              Activities closed within the <strong>last 18 months</strong> are
              also included (month-level accuracy; day precision is not
              required).
            </p>
            <table class="govuk-table">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Status Code</th>
                  <th scope="col" class="govuk-table__header">Label</th>
                  <th scope="col" class="govuk-table__header">Included</th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    <strong class="govuk-tag">1</strong>
                  </th>
                  <td class="govuk-table__cell">Pipeline / Identification</td>
                  <td class="govuk-table__cell">Yes (very few instances)</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    <strong class="govuk-tag">2</strong>
                  </th>
                  <td class="govuk-table__cell">Implementation</td>
                  <td class="govuk-table__cell">Yes</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    <strong class="govuk-tag">4</strong>
                  </th>
                  <td class="govuk-table__cell">Closed</td>
                  <td class="govuk-table__cell">
                    Yes — within last 18 months only
                  </td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    <strong class="govuk-tag">3 / 5 / 6</strong>
                  </th>
                  <td class="govuk-table__cell">
                    Finalisation / Cancelled / Suspended
                  </td>
                  <td class="govuk-table__cell">No</td>
                </tr>
              </tbody>
            </table>
            <!-- SECTION 1 - END -->

            <!-- SECTION 2 - START -->
            <h2 class="govuk-heading-m govuk-!-margin-top-8">
              Total Budget Calculation
            </h2>
            <h3 class="govuk-heading-s">Financial Year (April–March)</h3>
            <p>
              The <strong>Total Budget</strong> is the sum of all
              <strong class="blue">budget</strong> elements across
              <strong>H2 activities (projects)</strong> whose
              <strong class="blue">period-start</strong> and
              <strong class="blue">period-end</strong> fall within the current
              Financial Year (1 April – 31 March). Budgets are included
              regardless of the programme's activity status, because the budget
              period may differ from the 18-month activity scope window.
            </p>
            <!-- SECTION 2 - END -->

            <!-- SECTION 3 - START -->
            <hr
              class="govuk-section-break govuk-section-break--xl govuk-section-break--visible"
            />
            <h2 class="govuk-heading-m govuk-!-margin-top-0">
              Attribute Validation Rules
            </h2>
            <p>
              Applies to both H1 (programmes) and H2 (projects) unless noted.
              Each attribute contributes a
              <strong>percentage score</strong> (0–100) which feeds into the RAG
              ratings.
            </p>
            <h3 class="govuk-heading-s govuk-!-margin-bottom-0">Title</h3>
            <span class="govuk-caption-m govuk-!-margin-bottom-2"
              >Source: title.narrative (first element)</span
            >
            <table class="govuk-table govuk-!-margin-bottom-2">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Condition</th>
                  <th scope="col" class="govuk-table__header">Status</th>
                  <th scope="col" class="govuk-table__header">Message</th>
                  <th scope="col" class="govuk-table__header align_right">
                    Percentage
                  </th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Field missing or empty
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">Title is missing</td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Length &lt 60 characters
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    Title is too short (N characters, minimum 60 required)
                  </td>
                  <td class="govuk-table__cell align_right">len ÷ 60 × 100</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Contains unexpanded acronyms
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    Title contains potential acronyms that should be expanded:
                    ...
                  </td>
                  <td class="govuk-table__cell align_right">
                    (1 − Σ len(acronym) ÷ len(title)) × 100
                  </td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    All checks pass
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--green">PASS</strong>
                  </td>
                  <td class="govuk-table__cell">---</td>
                  <td class="govuk-table__cell align_right">100%</td>
                </tr>
              </tbody>
            </table>
            <span class="govuk-caption-m govuk-!-margin-bottom-8"
              >ⓘ Acronym detection regex:
              (?&lt!\w)(?:[A-Z]{2,}|[A-Za-z](?:\.[A-Za-z])+\.?)(?!\w). Words in
              data/non_acronyms.json are excluded.</span
            >
            <!-- SECTION 3 - END -->

            <!-- SECTION 4 - START -->
            <h3 class="govuk-heading-s govuk-!-margin-bottom-0">Description</h3>
            <span class="govuk-caption-m govuk-!-margin-bottom-2"
              >Source: description.narrative (first element), compared against
              title.narrative</span
            >
            <table class="govuk-table govuk-!-margin-bottom-2">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Condition</th>
                  <th scope="col" class="govuk-table__header">Status</th>
                  <th scope="col" class="govuk-table__header">Message</th>
                  <th scope="col" class="govuk-table__header align_right">
                    Percentage
                  </th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Field missing or empty
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">Description is missing</td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Description equals title (case-insensitive)
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    Description is a repeat of the title
                  </td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    len(description) ≤ len(title)
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    Description must be longer than title
                  </td>
                  <td class="govuk-table__cell align_right">
                    len(description) ÷ len(title) × 100
                  </td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    All checks pass
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--green">PASS</strong>
                  </td>
                  <td class="govuk-table__cell">---</td>
                  <td class="govuk-table__cell align_right">100%</td>
                </tr>
              </tbody>
            </table>
            <!-- SECTION 4 - END -->

            <!-- SECTION 5 - START -->
            <h3 class="govuk-heading-s govuk-!-margin-bottom-0">Start Date</h3>
            <span class="govuk-caption-m govuk-!-margin-bottom-2"
              >Source: activity-date.start-actual (first element)</span
            >
            <table class="govuk-table govuk-!-margin-bottom-2">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Condition</th>
                  <th scope="col" class="govuk-table__header">Status</th>
                  <th scope="col" class="govuk-table__header">Message</th>
                  <th scope="col" class="govuk-table__header align_right">
                    Percentage
                  </th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Field missing or empty
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">Start date is missing</td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Matches a known default/system date
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    Start date is a default system date: YYYY-MM-DD
                  </td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Cannot be parsed
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    Invalid start date format: ...
                  </td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    All checks pass
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--green">PASS</strong>
                  </td>
                  <td class="govuk-table__cell">---</td>
                  <td class="govuk-table__cell align_right">100%</td>
                </tr>
              </tbody>
            </table>
            <span class="govuk-caption-m govuk-!-margin-bottom-8"
              >ⓘ Default dates (e.g. 1900-01-01, 1970-01-01) are stored in
              data/default_dates.json and editable via the config API.</span
            >
            <!-- SECTION 5 - END -->

            <!-- SECTION 6 - START -->
            <h3 class="govuk-heading-s govuk-!-margin-bottom-0">End Date</h3>
            <span class="govuk-caption-m govuk-!-margin-bottom-2"
              >Source: activity-date.end-planned (preferred) or
              activity-date.end-actual</span
            >
            <table class="govuk-table govuk-!-margin-bottom-2">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Condition</th>
                  <th scope="col" class="govuk-table__header">Status</th>
                  <th scope="col" class="govuk-table__header">Message</th>
                  <th scope="col" class="govuk-table__header align_right">
                    Percentage
                  </th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Both end date fields missing
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">End date is missing</td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Cannot be parsed
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    Invalid end date format: ...
                  </td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    End date ≤ start date (when start date present)
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    End date must be after start date
                  </td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    All checks pass
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--green">PASS</strong>
                  </td>
                  <td class="govuk-table__cell">---</td>
                  <td class="govuk-table__cell align_right">100%</td>
                </tr>
              </tbody>
            </table>
            <!-- SECTION 6 - END -->

            <!-- SECTION 7 - START -->
            <h3 class="govuk-heading-s govuk-!-margin-bottom-0">Sector</h3>
            <span class="govuk-caption-m govuk-!-margin-bottom-2"
              >Source: sector.code / sector.percentage (activity-level);
              transaction.sector.code (fallback)</span
            >
            <table class="govuk-table govuk-!-margin-bottom-2">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Condition</th>
                  <th scope="col" class="govuk-table__header">Status</th>
                  <th scope="col" class="govuk-table__header">Message</th>
                  <th scope="col" class="govuk-table__header align_right">
                    Percentage
                  </th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    No activity-level AND no transaction-level sectors
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">No sectors defined</td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    No activity-level sectors, transaction-level present
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--grey">N/A</strong>
                  </td>
                  <td class="govuk-table__cell">
                    No activity-level sectors defined, only transaction-level
                    sectors
                  </td>
                  <td class="govuk-table__cell align_right">100%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Any sector code is not exactly 5 digits
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    All sectors must use 5-digit DAC CRS codes
                  </td>
                  <td class="govuk-table__cell align_right">
                    (valid ÷ total) × 100
                  </td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Sector percentages present and do not sum to 100% (±0.02)
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    Sector percentages must sum to 100% (got N%)
                  </td>
                  <td class="govuk-table__cell align_right">actual sum</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    All checks pass
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--green">PASS</strong>
                  </td>
                  <td class="govuk-table__cell">---</td>
                  <td class="govuk-table__cell align_right">100%</td>
                </tr>
              </tbody>
            </table>
            <span class="govuk-caption-m govuk-!-margin-bottom-8"
              >ⓘ Sector percentage tolerance is configurable (sector_tolerance,
              default ±0.02). Percentages are optional — if absent, only code
              validity is checked.</span
            >
            <!-- SECTION 7 - END -->

            <!-- SECTION 8 - START -->
            <h3 class="govuk-heading-s govuk-!-margin-bottom-0">Location</h3>
            <span class="govuk-caption-m govuk-!-margin-bottom-2"
              >Source: recipient-country and recipient-region codes/percentages;
              transaction-level codes as fallback</span
            >
            <table class="govuk-table govuk-!-margin-bottom-2">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Condition</th>
                  <th scope="col" class="govuk-table__header">Status</th>
                  <th scope="col" class="govuk-table__header">Message</th>
                  <th scope="col" class="govuk-table__header align_right">
                    Percentage
                  </th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Path A — transaction-level country/region codes present
                    (takes priority)
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--grey">N/A</strong>
                  </td>
                  <td class="govuk-table__cell">
                    No activity-level locations defined, only transaction-level
                    locations
                  </td>
                  <td class="govuk-table__cell align_right">100%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Path B — no codes at all (no percentages, no transaction
                    codes)
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    No location (country or region) specified
                  </td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Path B — exactly one country/region code (100% implied)
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--green">PASS</strong>
                  </td>
                  <td class="govuk-table__cell">---</td>
                  <td class="govuk-table__cell align_right">100%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Path B — multiple codes, no percentages
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    Multiple locations specified without percentages
                  </td>
                  <td class="govuk-table__cell align_right">0%</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Path C — activity-level percentages present, do not sum to
                    100%
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--red">FAIL</strong>
                  </td>
                  <td class="govuk-table__cell">
                    Location percentages must sum to 100% (got N%)
                  </td>
                  <td class="govuk-table__cell align_right">actual sum</td>
                </tr>
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">
                    Path C — percentages sum to 100% (±0.02)
                  </th>
                  <td class="govuk-table__cell">
                    <strong class="govuk-tag govuk-tag--green">PASS</strong>
                  </td>
                  <td class="govuk-table__cell">—--</td>
                  <td class="govuk-table__cell align_right">actual sum</td>
                </tr>
              </tbody>
            </table>
            <span class="govuk-caption-m govuk-!-margin-bottom-8"
              >ⓘ Location percentage tolerance is configurable
              (location_tolerance, default ±0.02). Evaluated via three mutually
              exclusive paths checked in order.</span
            >
